{
  "name": "styx-website",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:js": "eslint --format=pretty --ignore-path .gitignore .",
    "lint:css": "stylelint **/*.{pcss,css,html,svelte} --custom-formatter=node_modules/stylelint-formatter-pretty",
    "fix:js": "eslint --format=pretty --ignore-path .gitignore . --fix",
    "fix:css": "stylelint **/*.{pcss,css,html,svelte} --custom-formatter=node_modules/stylelint-formatter-pretty --fix"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^2.0.0",
    "@sveltejs/adapter-cloudflare": "^2.0.1",
    "@sveltejs/kit": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^5.51.0",
    "@typescript-eslint/parser": "^5.51.0",
    "autoprefixer": "^10.4.13",
    "eslint": "^8.34.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-formatter-pretty": "^4.1.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "postcss": "^8.4.21",
    "postcss-extend-rule": "^4.0.0",
    "postcss-html": "^1.5.0",
    "postcss-import": "^15.1.0",
    "postcss-load-config": "^4.0.1",
    "postcss-nested": "^6.0.0",
    "postcss-preset-env": "^8.0.1",
    "postcss-short": "^5.0.0",
    "postcss-simple-vars": "^7.0.1",
    "stylelint": "^15.1.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^30.0.1",
    "stylelint-formatter-pretty": "^3.1.1",
    "svelte": "^3.55.1",
    "svelte-check": "^3.0.3",
    "svelte-preprocess": "^5.0.1",
    "tslib": "^2.5.0",
    "typescript": "^4.9.5",
    "vite": "^4.1.1"
  },
  "type": "module",
  "dependencies": {
    "@fontsource/fira-mono": "^4.5.10"
  },
  "//future dependencies": {
    "@iconify/icons-twemoji": "^1.1.2",
    "@iconify/svelte": "^2.1.1",
    "@iconify/icons-mdi": "^1.1.42"
